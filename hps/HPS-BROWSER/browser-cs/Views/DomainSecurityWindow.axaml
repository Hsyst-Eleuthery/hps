<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HpsBrowser.Views.DomainSecurityWindow"
        Width="700" Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Segurança DNS">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="10">
      <TextBlock Text="Segurança do Domínio" FontSize="16" FontWeight="Bold" />
      <TextBlock x:Name="StatusText" FontSize="12" FontWeight="Bold" />

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Detalhes do Domínio" FontWeight="Bold" />
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
            <TextBlock Text="Domínio:" Grid.Row="0" Grid.Column="0" />
            <TextBlock x:Name="DomainText" Grid.Row="0" Grid.Column="1" />
            <TextBlock Text="Hash:" Grid.Row="1" Grid.Column="0" />
            <TextBlock x:Name="HashText" Grid.Row="1" Grid.Column="1" />
            <TextBlock Text="Usuário:" Grid.Row="2" Grid.Column="0" />
            <TextBlock x:Name="UserText" Grid.Row="2" Grid.Column="1" />
            <TextBlock Text="Dono:" Grid.Row="3" Grid.Column="0" />
            <TextBlock x:Name="OwnerText" Grid.Row="3" Grid.Column="1" />
            <TextBlock Text="Certificador:" Grid.Row="4" Grid.Column="0" />
            <TextBlock x:Name="CertifierText" Grid.Row="4" Grid.Column="1" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Assinatura" FontWeight="Bold" />
          <TextBlock Text="Assinatura:" />
          <TextBox x:Name="SignatureText" AcceptsReturn="True" Height="60" IsReadOnly="True" />
        </StackPanel>
      </Border>

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Contratos Relacionados" FontWeight="Bold" />
          <TextBox x:Name="ContractsText" AcceptsReturn="True" Height="120" IsReadOnly="True" />
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Fechar" x:Name="CloseButton" Width="120" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
