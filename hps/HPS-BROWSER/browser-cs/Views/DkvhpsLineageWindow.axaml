<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels"
        x:Class="HpsBrowser.Views.DkvhpsLineageWindow"
        x:DataType="vm:MainViewModel"
        Width="980" Height="620"
        Title="DKVHPS: vouchers da linhagem">
  <Grid RowDefinitions="Auto,*,Auto,*" Margin="12">
    <TextBlock Text="{Binding DkvhpsLineageDetails}" TextWrapping="Wrap" />
    <DataGrid Grid.Row="1"
              Margin="0,10,0,10"
              ItemsSource="{Binding DkvhpsLineageVouchers}"
              SelectedItem="{Binding SelectedDkvhpsVoucher}"
              Background="#1A1A1A"
              Foreground="#EAEAEA"
              HeadersVisibility="Column"
              GridLinesVisibility="All"
              AutoGenerateColumns="False"
              IsReadOnly="True">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Depth" Binding="{Binding LineageDepth}" Width="70" />
        <DataGridTextColumn Header="Voucher" Binding="{Binding VoucherId}" Width="220" />
        <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="80" />
        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="180" />
        <DataGridTextColumn Header="Integridade" Binding="{Binding IntegritySummary}" Width="220" />
        <DataGridTextColumn Header="Hash Voucher" Binding="{Binding VoucherHashStatus}" Width="120" />
        <DataGridTextColumn Header="Hash Linhagem" Binding="{Binding LineageHashStatus}" Width="130" />
        <DataGridCheckBoxColumn Header="Invalidado" Binding="{Binding Invalidated}" Width="90" />
      </DataGrid.Columns>
    </DataGrid>
    <TextBlock Grid.Row="2"
               Text="Voucher descriptografado"
               FontWeight="Bold"
               Margin="0,0,0,8" />
    <TextBox Grid.Row="3"
             Text="{Binding DkvhpsVoucherDetails}"
             AcceptsReturn="True"
             IsReadOnly="True"
             TextWrapping="Wrap"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
  </Grid>
</Window>
