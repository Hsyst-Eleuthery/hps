<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels"
        x:Class="HpsBrowser.Views.PowMonitorWindow"
        x:DataType="vm:MainViewModel"
        Width="520" Height="360"
        Title="Monitoramento PoW">
  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="10" Margin="12">
      <TextBlock Text="Monitoramento PoW" FontSize="16" FontWeight="Bold" />
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
        <TextBlock Text="Status:" Grid.Row="0" />
        <TextBlock Text="{Binding PowStatus}" Grid.Row="0" Grid.Column="1" />
        <TextBlock Text="Ação:" Grid.Row="1" />
        <TextBlock Text="{Binding PowActionType}" Grid.Row="1" Grid.Column="1" />
        <TextBlock Text="Bits alvo:" Grid.Row="2" />
        <TextBlock Text="{Binding PowTargetBits}" Grid.Row="2" Grid.Column="1" />
        <TextBlock Text="Tempo:" Grid.Row="3" />
        <TextBlock Text="{Binding PowElapsed}" Grid.Row="3" Grid.Column="1" />
        <TextBlock Text="Hashrate:" Grid.Row="4" />
        <TextBlock Text="{Binding PowHashrate}" Grid.Row="4" Grid.Column="1" />
        <TextBlock Text="Tentativas:" Grid.Row="5" />
        <TextBlock Text="{Binding PowAttempts}" Grid.Row="5" Grid.Column="1" />
      </Grid>
      <ProgressBar IsIndeterminate="True" Height="6" IsVisible="{Binding IsPowActive}" />
      <TextBox AcceptsReturn="True"
               MinHeight="140"
               Text="{Binding PowLogText}"
               IsReadOnly="True"
               TextWrapping="Wrap"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Cancelar PoW" Command="{Binding CancelPowCommand}" IsEnabled="{Binding IsPowActive}" />
        <Button Content="Fechar" Command="{Binding ClosePowMonitorCommand}" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>