<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels"
        x:Class="HpsBrowser.Views.FlowTimeoutPopupWindow"
        x:DataType="vm:MainViewModel"
        Width="480" Height="300"
        Title="Tempo limite excedido"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid>
    <Border Background="#1A000000" CornerRadius="6" BorderBrush="#FF4444" BorderThickness="1" Padding="15">
      <StackPanel Spacing="10">
        <TextBlock Text="Tempo limite excedido!" FontWeight="Bold" Foreground="#FF6B6B" FontSize="16" />
        <TextBlock Text="{Binding FlowTimeoutOverlayMessage}" TextWrapping="Wrap" Foreground="#EAEAEA" />
        <TextBox Text="{Binding FlowExtendSecondsText}"
                 IsVisible="{Binding FlowExtendInputVisible}"
                 Watermark="Segundos adicionais..."
                 Width="140"
                 HorizontalAlignment="Left" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Esperar mais 30s" Command="{Binding ExtendFlowTimeout30Command}" />
          <Button Content="Esperar mais 60s" Command="{Binding ExtendFlowTimeout60Command}" />
          <Button Content="Esperar mais 120s" Command="{Binding ExtendFlowTimeout120Command}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Indefinidamente" Command="{Binding ExtendFlowTimeoutIndefiniteCommand}" />
          <Button Content="Esperar customizado" Command="{Binding ExtendFlowTimeoutCustomCommand}"
                  IsVisible="{Binding FlowExtendInputVisible}" />
          <Button Content="Parar" Command="{Binding CancelFlowCommand}" />
        </StackPanel>
        <TextBlock Text="{Binding FlowResponseRemaining}" Foreground="#FF6B6B" FontSize="12" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
