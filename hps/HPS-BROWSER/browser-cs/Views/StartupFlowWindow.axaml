<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HpsBrowser.Views.StartupFlowWindow"
        Width="520" Height="300"
        CanResize="False"
        Title="Abertura Segura">
  <StackPanel Margin="14" Spacing="10">
    <TextBlock x:Name="IntroTextBlock"
               Text="Etapas para abrir o ambiente com segurança."
               TextWrapping="Wrap" />
    <Border Background="#141414" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
      <StackPanel Spacing="8">
        <TextBlock x:Name="ProgressTitleTextBlock" Text="Etapas da abertura" FontWeight="Bold" />
        <TextBlock x:Name="ProgressStatusTextBlock"
                   Text="Clique no tópico pendente para continuar."
                   Foreground="#B8B8B8"
                   TextWrapping="Wrap" />
        <StackPanel Spacing="6">
          <Button x:Name="StepOneButton" HorizontalAlignment="Left" Content="[..] Informar usuário e senha" />
          <TextBlock x:Name="StepOneHintTextBlock" Margin="16,0,0,0" Foreground="Red" IsVisible="True" Text="PENDENTE: clique para resolver" />
          <Button x:Name="StepTwoButton" HorizontalAlignment="Left" Content="[ ] Desbloquear chave mestra" Opacity="0.45" />
          <Button x:Name="StepThreeButton" HorizontalAlignment="Left" Content="[ ] Carregar chaves operacionais" Opacity="0.45" />
        </StackPanel>
      </StackPanel>
    </Border>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="CancelButton" Content="Cancelar" />
    </StackPanel>
  </StackPanel>
</Window>
