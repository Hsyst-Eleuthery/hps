<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:HpsBrowser.Models;assembly=HpsBrowser.Core"
        xmlns:conv="clr-namespace:HpsBrowser.Converters;assembly=HpsBrowser.Core"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels;assembly=HpsBrowser.Core"
        x:Class="HpsBrowser.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="650"
        Title="Navegador P2P Hsyst">
  <Window.Resources>
    <conv:ContractRowBackgroundConverter x:Key="ContractRowBackgroundConverter" />
  </Window.Resources>
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <TextBlock Text="Navegador P2P Hsyst"
               FontSize="20"
               FontWeight="Bold"
               Margin="4,0,4,12" />

    <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedMainTabIndex}">
      <TabItem Header="Login">
        <ScrollViewer>
          <StackPanel Spacing="10" Margin="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Entrar na Rede P2P" FontSize="16" FontWeight="Bold" />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="login" />
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
              <TextBlock Text="Servidor:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="1"
                        ItemsSource="{Binding KnownServers}"
                        SelectedItem="{Binding SelectedServer}"
                        DisplayMemberBinding="{Binding Address}"
                        IsEditable="True"
                        Text="{Binding ServerAddress}"
                        ToolTip.Tip="Selecione ou digite o servidor (host:porta) para entrar na rede." />

              <TextBlock Text="Usuário:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Username}" ToolTip.Tip="Digite seu usuário na rede." />

              <TextBlock Text="Senha da chave:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding KeyPassphrase}" PasswordChar="*" ToolTip.Tip="Senha local para desbloquear suas chaves .hps.key." />

              <CheckBox Grid.Row="3" Grid.Column="1" Content="Login automático" IsChecked="{Binding AutoLogin}" ToolTip.Tip="Tenta entrar automaticamente na rede ao abrir." />
              <CheckBox Grid.Row="4" Grid.Column="1" Content="Salvar chaves criptográficas" IsChecked="{Binding SaveKeys}" ToolTip.Tip="Mantém suas chaves criptográficas salvas no dispositivo." />
              <CheckBox Grid.Row="5" Grid.Column="1" Content="Usar SSL/TLS" IsChecked="{Binding UseSsl}" ToolTip.Tip="Ative se o servidor usa TLS/HTTPS." />
              <CheckBox Grid.Row="6" Grid.Column="1" Content="Reconexão automática" IsChecked="{Binding AutoReconnect}" ToolTip.Tip="Tenta reconectar caso a rede caia." />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Entrar na Rede" Command="{Binding EnterNetworkCommand}" ToolTip.Tip="Conecta ao servidor e inicia o login." />
              <Button Content="Sair da Rede" Command="{Binding ExitNetworkCommand}" ToolTip.Tip="Desconecta da rede P2P." />
            </StackPanel>
            <TextBlock Text="{Binding LoginStatus}" Foreground="Red" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Navegador" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <Grid RowDefinitions="Auto,*" ColumnDefinitions="*" Margin="8" RowSpacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Voltar" Command="{Binding BackCommand}" ToolTip.Tip="Volta para a página anterior." />
              <Button Content="Avançar" Command="{Binding ForwardCommand}" ToolTip.Tip="Avança para a próxima página." />
              <Button Content="Recarregar" Command="{Binding ReloadCommand}" ToolTip.Tip="Recarrega o conteúdo atual." />
              <Button Content="Início" Command="{Binding HomeCommand}" ToolTip.Tip="Vai para hps://rede." />
              <TextBox Width="500" Watermark="hps://rede" Text="{Binding BrowserUrl}" KeyDown="OnBrowserUrlKeyDown" ToolTip.Tip="Use hps://&lt;hash&gt; ou hps://dns:&lt;dominio&gt;." />
              <Button Content="Segurança" Command="{Binding ShowBrowserSecurityCommand}" ToolTip.Tip="Mostra informações de segurança do conteúdo." />
              <Button Content="Buscar" Command="{Binding OpenSearchCommand}" ToolTip.Tip="Abre a busca de conteúdo." />
              <Button Content="Ir" Command="{Binding NavigateCommand}" ToolTip.Tip="Navega para o endereço informado." />
              <Button Content="Salvar" Command="{Binding SaveContentCommand}" ToolTip.Tip="Salva o conteúdo atual no disco." />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="browser" />
            </StackPanel>
            <Grid Grid.Row="1" RowDefinitions="*,Auto">
              <TextBox AcceptsReturn="True"
                       TextWrapping="NoWrap"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       IsReadOnly="True"
                       Text="{Binding BrowserContent}"
                       IsVisible="{Binding IsBrowserTextVisible}" />
              <Image Grid.Row="1" Height="240" Stretch="Uniform" Source="{Binding BrowserImage}" IsVisible="{Binding IsBrowserImageVisible}" />
              <Border Grid.RowSpan="2"
                      Background="#A30000"
                      BorderBrush="#FF4D4D"
                      BorderThickness="2"
                      Padding="18"
                      IsVisible="{Binding IsCriticalBrowserErrorVisible}">
                <StackPanel Spacing="10">
                  <TextBlock Text="Tela vermelha da morte" FontSize="24" FontWeight="Bold" Foreground="White" />
                  <TextBlock Text="{Binding CriticalBrowserErrorCode}" FontSize="16" FontWeight="Bold" Foreground="#FFE5E5" />
                  <TextBlock Text="{Binding CriticalBrowserErrorTitle}" FontSize="18" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding CriticalBrowserErrorMessage}" Foreground="White" TextWrapping="Wrap" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Fechar" Command="{Binding CloseCriticalBrowserErrorCommand}" />
                    <Button Content="Resolver problema"
                            Command="{Binding ResolveCriticalBrowserErrorCommand}"
                            IsVisible="{Binding CanResolveCriticalBrowserError}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="DNS" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10" Margin="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Sistema de Nomes Descentralizado" FontSize="16" FontWeight="Bold" />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="dns" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Domínio:" VerticalAlignment="Center" />
              <TextBox Width="320" Text="{Binding DnsDomain}" ToolTip.Tip="Domínio que você quer registrar ou resolver." />
              <Button Content="Registrar" Command="{Binding RegisterDnsCommand}" ToolTip.Tip="Registra o domínio apontando para o hash." />
              <Button Content="Resolver" Command="{Binding ResolveDnsCommand}" ToolTip.Tip="Resolve o domínio para obter o conteúdo." />
              <Button Content="Segurança" Command="{Binding ShowDnsSecurityCommand}" ToolTip.Tip="Mostra a segurança do registro DNS." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Hash do conteúdo:" VerticalAlignment="Center" />
              <TextBox Width="420" Text="{Binding DnsContentHash}" ToolTip.Tip="Hash de 64 caracteres do conteúdo." />
              <Button Content="Selecionar Arquivo" Command="{Binding SelectDnsFileCommand}" ToolTip.Tip="Escolha um arquivo local para preencher o hash." />
            </StackPanel>
            <TextBlock Text="{Binding DnsStatus}" Foreground="Red" />
            <DataGrid Height="300"
                      ItemsSource="{Binding DnsRecords}"
                      SelectedItem="{Binding SelectedDnsRecord}"
                      Background="#1A1A1A"
                      Foreground="#EAEAEA"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Domínio" Binding="{Binding Domain}" Width="200" />
                <DataGridTextColumn Header="Hash do Conteúdo" Binding="{Binding ContentHash}" Width="*" />
                <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="140" />
                <DataGridCheckBoxColumn Header="Verificado" Binding="{Binding Verified}" Width="120" />
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Upload" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10" Margin="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Upload de Conteúdo" FontSize="16" FontWeight="Bold" />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="upload" />
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
              <TextBlock Text="Arquivo:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding UploadFilePath}" />
              <Button Grid.Row="0" Grid.Column="2" Content="Selecionar" Command="{Binding SelectUploadFileCommand}" />

              <TextBlock Text="Título:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding UploadTitle}" />

              <TextBlock Text="Descrição:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding UploadDescription}" />

              <TextBlock Text="Tipo MIME:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
              <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding UploadMimeType}" />

              <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Content="Upload" Command="{Binding UploadCommand}" />
            </Grid>
            <TextBlock Text="{Binding UploadStatus}" Foreground="Red" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Hash:" VerticalAlignment="Center" />
              <TextBox x:Name="UploadHashTextBox"
                       Width="420"
                       Text="{Binding UploadHash}"
                       IsReadOnly="True"
                       KeyDown="OnUploadHashKeyDown" />
              <Button Content="Copiar" Click="OnCopyUploadHashClick" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Ações HPS" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Ações HPS" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="actions" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Tipo:" VerticalAlignment="Center" />
            <ComboBox Width="260"
                      ItemsSource="{Binding HpsActionTypes}"
                      SelectedItem="{Binding SelectedHpsAction}" />
          </StackPanel>

          <StackPanel Spacing="8" IsVisible="{Binding IsHpsActionFile}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Usuário destino:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsTargetUser}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Hash do conteúdo:" VerticalAlignment="Center" />
              <TextBox Width="420" Text="{Binding HpsContentHash}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="8" IsVisible="{Binding IsHpsActionHps}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Usuário destino:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsTargetUser}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Valor (HPS):" VerticalAlignment="Center" />
              <TextBox Width="160" Text="{Binding HpsTransferAmount}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="8" IsVisible="{Binding IsHpsActionDomain}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Domínio:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsDomain}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Novo dono:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsNewOwner}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="8" IsVisible="{Binding IsHpsActionApiTransfer}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Usuário destino:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsTargetUser}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Nome do App:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsAppName}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="8" IsVisible="{Binding IsHpsActionApiCreate}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Nome do App:" VerticalAlignment="Center" />
              <TextBox Width="260" Text="{Binding HpsAppName}" />
            </StackPanel>
          </StackPanel>

          <Button Content="Aplicar Ação" Command="{Binding ApplyHpsActionCommand}" HorizontalAlignment="Left" />
          <TextBlock Text="{Binding HpsActionStatus}" Foreground="Red" />
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Carteira HPS" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10" Margin="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Carteira HPS" FontSize="16" FontWeight="Bold" />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="wallet" />
            </StackPanel>
            <TextBlock Text="{Binding HpsBalance, StringFormat=Saldo: {0}}" />
            <TextBlock Text="{Binding HpsWalletAlert}" Foreground="#F0B37E" FontWeight="Bold" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Motivo:" VerticalAlignment="Center" />
              <TextBox Width="220" Text="{Binding HpsMintReason}" />
              <Button Content="Minerar HPS (PoW)" Command="{Binding StartHpsMintCommand}" />
              <Button Content="Atualizar" Command="{Binding RequestHpsWalletCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding HpsMintStatus}" Foreground="Red" />
            <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Mineração contínua" FontWeight="Bold" />
                  <TextBlock Text="{Binding HpsMiningStatus}" Foreground="#EAEAEA" />
                </StackPanel>
                <CheckBox Content="Ativar mineração contínua"
                          IsChecked="{Binding IsContinuousMiningEnabled}"
                          Foreground="#EAEAEA" />
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                  <TextBlock Text="Bits alvo:" Grid.Row="0" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningBits}" Grid.Row="0" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Tempo decorrido:" Grid.Row="0" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningElapsed}" Grid.Row="0" Grid.Column="3" Foreground="#EAEAEA" />

                  <TextBlock Text="Hashrate:" Grid.Row="1" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningHashrate}" Grid.Row="1" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Tentativas:" Grid.Row="1" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningAttempts}" Grid.Row="1" Grid.Column="3" Foreground="#EAEAEA" />

                  <TextBlock Text="Minerações concluídas:" Grid.Row="2" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningCount}" Grid.Row="2" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Tempo total:" Grid.Row="2" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding HpsMiningTotalTime}" Grid.Row="2" Grid.Column="3" Foreground="#EAEAEA" />

                  <TextBlock Text="Pendências de assinatura:" Grid.Row="3" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerPendingSignatures}" Grid.Row="3" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Vouchers pendentes:" Grid.Row="3" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerWithheldCount}" Grid.Row="3" Grid.Column="3" Foreground="#EAEAEA" />

                  <TextBlock Text="Valor pendente:" Grid.Row="4" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerWithheldValue}" Grid.Row="4" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Multa pendente:" Grid.Row="4" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerFineAmount}" Grid.Row="4" Grid.Column="3" Foreground="#EAEAEA" />

                  <TextBlock Text="Pendências de multa:" Grid.Row="5" Grid.Column="0" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerPendingFines}" Grid.Row="5" Grid.Column="1" Foreground="#EAEAEA" />
                  <TextBlock Text="Pendências atraso:" Grid.Row="5" Grid.Column="2" Foreground="#EAEAEA" />
                  <TextBlock Text="{Binding MinerPendingDelayFines}" Grid.Row="5" Grid.Column="3" Foreground="#EAEAEA" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Pagar multa" Command="{Binding RequestMinerFineCommand}" />
                  <CheckBox Content="Pagamento automático" IsChecked="{Binding MinerAutoPayFine}" Foreground="#EAEAEA" />
                  <CheckBox Content="Promessa automática" IsChecked="{Binding MinerFinePromise}" Foreground="#EAEAEA" />
                </StackPanel>
                <TextBlock Text="{Binding MinerFineStatus}" Foreground="#F0B37E" />
                <TextBox AcceptsReturn="True" Height="100" Text="{Binding PowLogText}" IsReadOnly="True" />
              </StackPanel>
            </Border>
            <DataGrid Height="300"
                      ItemsSource="{Binding Vouchers}"
                      Background="#1A1A1A"
                      Foreground="#EAEAEA"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Voucher ID" Binding="{Binding VoucherId}" Width="200" />
                <DataGridTextColumn Header="Emissor" Binding="{Binding Issuer}" Width="200" />
                <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="100" />
                <DataGridTextColumn Header="Status" Binding="{Binding DisplayStatus}" Width="220" />
              </DataGrid.Columns>
            </DataGrid>
          </StackPanel>
          </ScrollViewer>
        </TabItem>

      <TabItem Header="DKVHPS" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10" Margin="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Auditoria DKVHPS" FontSize="16" FontWeight="Bold" />
              <Button Content="Ajuda" Click="OnHelpClick" Tag="dkvhps" />
            </StackPanel>
            <TextBlock Text="{Binding DkvhpsStatus}" Foreground="#EAEAEA" TextWrapping="Wrap" />
            <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
              <Border Grid.Row="0" Grid.Column="0" Background="#141414" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                  <TextBlock Text="Resumo da linhagem selecionada" FontSize="14" FontWeight="Bold" Foreground="#EAEAEA" />
                  <TextBox Text="{Binding DkvhpsLineageDetails}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" MinHeight="180" />
                </StackPanel>
              </Border>
              <Border Grid.Row="0" Grid.Column="1" Background="#141414" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                  <TextBlock Text="Fluxo de auditoria" FontSize="14" FontWeight="Bold" Foreground="#EAEAEA" />
                  <TextBlock Text="1. Escolha uma linhagem abaixo."
                             Foreground="#AFAFAF"
                             TextWrapping="Wrap" />
                  <TextBlock Text="2. Abra o popup da linhagem para ver a tabela completa de vouchers."
                             Foreground="#AFAFAF"
                             TextWrapping="Wrap" />
                  <TextBlock Text="3. Dentro do popup, ao selecionar um voucher, o conteúdo descriptografado aparece logo abaixo da tabela."
                             Foreground="#AFAFAF"
                             TextWrapping="Wrap" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Abrir vouchers da linhagem" Command="{Binding OpenDkvhpsLineageVouchersCommand}" />
                    <Button Content="Abrir detalhe técnico" Command="{Binding OpenDkvhpsLineageDetailsCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#141414" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Linhagens disponíveis" FontSize="14" FontWeight="Bold" Foreground="#EAEAEA" />
                    <Button Content="Abrir popup da linhagem" Command="{Binding OpenDkvhpsLineageVouchersCommand}" />
                  </StackPanel>
                  <TextBlock Text="A lista abaixo concentra as linhagens locais. O popup mostra a tabela completa de vouchers e o material descriptografado do item selecionado."
                             Foreground="#AFAFAF"
                             TextWrapping="Wrap" />
                  <DataGrid Height="320"
                            ItemsSource="{Binding DkvhpsLineages}"
                            SelectedItem="{Binding SelectedDkvhpsLineage}"
                            x:CompileBindings="False"
                            Background="#1A1A1A"
                            Foreground="#EAEAEA"
                            RowHeight="34"
                            HeadersVisibility="Column"
                            GridLinesVisibility="All"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            CanUserSortColumns="True">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Linhagem" Binding="{Binding LineageRootVoucherId}" Width="220" />
                      <DataGridTextColumn Header="Voucher Ativo" Binding="{Binding ActiveVoucherId}" Width="220" />
                      <DataGridTextColumn Header="Total" Binding="{Binding TotalValue}" Width="90" />
                      <DataGridTextColumn Header="Qtd" Binding="{Binding VoucherCount}" Width="80" />
                      <DataGridTextColumn Header="Status Ativo" Binding="{Binding ActiveStatus}" Width="160" />
                      <DataGridTextColumn Header="Integridade" Binding="{Binding IntegritySummary}" Width="220" />
                      <DataGridTextColumn Header="Origem" Binding="{Binding LineageOrigin}" Width="220" />
                    </DataGrid.Columns>
                  </DataGrid>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Câmbio" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Câmbio" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="exchange" />
          </StackPanel>
          <TextBlock Text="Economia por servidor" FontWeight="Bold" />
          <DataGrid Height="160"
                    ItemsSource="{Binding ExchangeServers}"
                    Background="#1A1A1A"
                    Foreground="#EAEAEA"
                    HeadersVisibility="Column"
                    GridLinesVisibility="All"
                    AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Servidor" Binding="{Binding Server}" Width="220" />
              <DataGridTextColumn Header="Total" Binding="{Binding TotalMinted}" Width="90" />
              <DataGridTextColumn Header="Multiplicador" Binding="{Binding Multiplier}" Width="120" />
              <DataGridTextColumn Header="Taxa" Binding="{Binding ExchangeFeeRate}" Width="90" />
              <DataGridTextColumn Header="Atualizado" Binding="{Binding UpdatedAt}" Width="140" />
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Emissor:" VerticalAlignment="Center" />
            <ComboBox Width="260"
                      ItemsSource="{Binding ExchangeIssuers}"
                      SelectedItem="{Binding SelectedExchangeIssuer}"
                      DisplayMemberBinding="{Binding Issuer}" />
            <Button Content="Solicitar Cotação" Command="{Binding RequestExchangeQuoteCommand}" />
          </StackPanel>
          <DataGrid Height="220"
                    ItemsSource="{Binding ExchangeIssuers}"
                    SelectedItem="{Binding SelectedExchangeIssuer}"
                    Background="#1A1A1A"
                    Foreground="#EAEAEA"
                    HeadersVisibility="Column"
                    GridLinesVisibility="All"
                    AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Emissor" Binding="{Binding Issuer}" Width="240" />
              <DataGridTextColumn Header="Qtd" Binding="{Binding Count}" Width="80" />
              <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="80" />
            </DataGrid.Columns>
          </DataGrid>
          <TextBlock Text="{Binding ExchangeStatus}" />
          <TextBlock Text="{Binding ExchangeQuoteMessage}" />
          <Button Content="Confirmar Conversão" Command="{Binding ConfirmExchangeCommand}" />
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Rede" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Rede P2P" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="network" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Atualizar" Command="{Binding RefreshNetworkCommand}" />
            <Button Content="Sincronizar" Command="{Binding SyncNetworkCommand}" />
            <Button Content="Meu Nó" Command="{Binding ShowMyNodeCommand}" />
          </StackPanel>
          <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,*" ColumnSpacing="12">
            <StackPanel Grid.Column="0" Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Buscar nó:" VerticalAlignment="Center" />
                <TextBox Width="220" Text="{Binding NetworkNodeSearch}" Watermark="ID, usuário ou endereço" />
              </StackPanel>
              <DataGrid Height="340"
                        ItemsSource="{Binding NetworkNodesView}"
                        SelectedItem="{Binding SelectedNetworkNode}"
                        x:CompileBindings="False"
                        Background="#1A1A1A"
                        Foreground="#EAEAEA"
                        HeadersVisibility="Column"
                        GridLinesVisibility="All"
                        AutoGenerateColumns="False">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="150" />
                  <DataGridTextColumn Header="ID do Nó" Binding="{Binding NodeId}" Width="180" />
                  <DataGridTextColumn Header="Endereço" Binding="{Binding Address}" Width="180" />
                  <DataGridTextColumn Header="Tipo" Binding="{Binding NodeType}" Width="110" />
                  <DataGridTextColumn Header="Reputação" Binding="{Binding Reputation}" Width="100" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                </DataGrid.Columns>
              </DataGrid>
            </StackPanel>
            <Border Grid.Column="1" Background="#141414" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Text="Resumo do nó selecionado" FontSize="14" FontWeight="Bold" Foreground="#EAEAEA" />
                <TextBlock Text="{Binding SelectedNetworkNode.Username, StringFormat=Usuário: {0}}" Foreground="#9CC3FF" />
                <TextBlock Text="{Binding SelectedNetworkNode.NodeId, StringFormat=ID do nó: {0}}" Foreground="#EAEAEA" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SelectedNetworkNode.Address, StringFormat=Endereço: {0}}" Foreground="#EAEAEA" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SelectedNetworkNode.NodeType, StringFormat=Tipo: {0}}" Foreground="#EAEAEA" />
                <TextBlock Text="{Binding SelectedNetworkNode.Status, StringFormat=Status: {0}}" Foreground="#EAEAEA" />
              </StackPanel>
            </Border>
          </Grid>
          <TextBlock Text="{Binding NetworkStats}" />
          <TextBlock Text="{Binding NetworkStatus}" Foreground="Red" />
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Certificados" IsVisible="{Binding IsLoggedIn}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Contratos, Vouchers e Gastos" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="contracts" />
          </StackPanel>
          <TextBlock Text="{Binding PendingTransferStatus}" Foreground="Red" />
          <TabControl>
            <TabItem Header="Pendências">
              <StackPanel Spacing="8" Margin="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Pendências ativas:" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding PendingTransfersCount}" VerticalAlignment="Center" />
                  <Button Content="Atualizar" Command="{Binding RefreshPendingTransfersCommand}" />
                </StackPanel>
                <DataGrid Height="200"
                          ItemsSource="{Binding PendingTransfers}"
                          SelectedItem="{Binding SelectedPendingTransfer}"
                          x:CompileBindings="False"
                          Background="#1A1A1A"
                          RowBackground="#1A1A1A"
                          Foreground="#EAEAEA"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TransferType}" Width="160" />
                    <DataGridTextColumn Header="Hash" Binding="{Binding ContentHash}" Width="200" />
                    <DataGridTextColumn Header="Domínio" Binding="{Binding Domain}" Width="140" />
                    <DataGridTextColumn Header="App" Binding="{Binding AppName}" Width="120" />
                    <DataGridTextColumn Header="Origem" Binding="{Binding OriginalOwner}" Width="120" />
                    <DataGridTextColumn Header="Destino" Binding="{Binding TargetUser}" Width="120" />
                  </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Aceitar" Command="{Binding AcceptTransferCommand}" />
                  <Button Content="Rejeitar" Command="{Binding RejectTransferCommand}" />
                  <Button Content="Renunciar" Command="{Binding RenounceTransferCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding TransferStatus}" Foreground="Red" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Vouchers">
              <StackPanel Spacing="8" Margin="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Voucher ID(s):" VerticalAlignment="Center" />
                  <TextBox Width="240" Text="{Binding VoucherAuditInput}" />
                  <Button Content="Analisar" Command="{Binding AnalyzeVouchersCommand}" />
                  <Button Content="Limpar" Command="{Binding ClearVoucherAuditCommand}" />
                  <Button Content="Ver contrato" Command="{Binding OpenVoucherAuditContractCommand}" />
                </StackPanel>
                <TextBox AcceptsReturn="True" Height="140" Text="{Binding VoucherAuditSummary}" IsReadOnly="True" />
                <TextBox AcceptsReturn="True" Height="200" Text="{Binding VoucherAuditDetails}" IsReadOnly="True" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Contratos">
              <StackPanel Spacing="8" Margin="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Filtro:" VerticalAlignment="Center" />
                  <ComboBox Width="120"
                            ItemsSource="{Binding ContractFilterOptions}"
                            SelectedItem="{Binding ContractFilter}" />
                  <TextBox Width="240" Text="{Binding ContractSearchValue}" Watermark="ID, titulo, hash, dominio..." />
                  <Button Content="Buscar" Command="{Binding SearchContractsCommand}" />
                  <Button Content="Limpar" Command="{Binding ClearContractsCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Content="Página anterior" Command="{Binding PreviousContractsPageCommand}" />
                  <Button Content="Próxima página" Command="{Binding NextContractsPageCommand}" />
                  <TextBlock Text="{Binding ContractPageStatus}" VerticalAlignment="Center" />
                </StackPanel>
                <DataGrid Height="220"
                          ItemsSource="{Binding Contracts}"
                          SelectedItem="{Binding SelectedContract}"
                          Background="#1A1A1A"
                          RowBackground="#1A1A1A"
                          Foreground="#EAEAEA"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                  <DataGrid.Styles>
                    <Style Selector="DataGridRow" x:DataType="models:ContractInfo">
                      <Setter Property="Background">
                        <MultiBinding Converter="{StaticResource ContractRowBackgroundConverter}">
                          <Binding Path="IsContractViolation" />
                          <Binding Path="IsPendingTransfer" />
                        </MultiBinding>
                      </Setter>
                    </Style>
                  </DataGrid.Styles>
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ContractId}" Width="200" />
                    <DataGridTextColumn Header="Titulo" Binding="{Binding ContractTitle}" Width="200" />
                    <DataGridTextColumn Header="Ação" Binding="{Binding ActionType}" Width="120" />
                    <DataGridTextColumn Header="Hash" Binding="{Binding ContentHash}" Width="160" />
                    <DataGridTextColumn Header="Domínio" Binding="{Binding Domain}" Width="120" />
                    <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="120" />
                    <DataGridTextColumn Header="Verificado" Binding="{Binding Verified}" Width="90" />
                  </DataGrid.Columns>
                </DataGrid>
                <TextBox AcceptsReturn="True" Height="160" Text="{Binding ContractDetailsText}" IsReadOnly="True" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Ver contrato" Command="{Binding OpenContractAnalyzerCommand}" />
                  <Button Content="Aceitar Transferência" Command="{Binding AcceptTransferCommand}" />
                  <Button Content="Rejeitar Transferência" Command="{Binding RejectTransferCommand}" />
                  <Button Content="Renunciar" Command="{Binding RenounceTransferCommand}" />
                  <Button Content="Pedir revogação" Command="{Binding RequestIssuerRecheckCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding TransferStatus}" Foreground="Red" />
                <TextBlock Text="{Binding IssuerRecheckStatus}" Foreground="#F0B37E" TextWrapping="Wrap" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Gastos">
              <StackPanel Spacing="8" Margin="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Voucher ou Contrato:" VerticalAlignment="Center" />
                  <TextBox Width="240" Text="{Binding SpendAuditInput}" />
                  <Button Content="Analisar" Command="{Binding AnalyzeSpendCommand}" />
                  <Button Content="Limpar" Command="{Binding ClearSpendAuditCommand}" />
                  <Button Content="Ver contrato" Command="{Binding OpenSpendContractCommand}" />
                </StackPanel>
                <TextBox AcceptsReturn="True" Height="140" Text="{Binding SpendAuditSummary}" IsReadOnly="True" />
                <TextBox AcceptsReturn="True" Height="200" Text="{Binding SpendAuditDetails}" IsReadOnly="True" />
              </StackPanel>
            </TabItem>
            <TabItem Header="pHPS">
              <StackPanel Spacing="8" Margin="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Mercado de Títulos da Custódia" FontWeight="Bold" />
                  <Button Content="Ajuda" Click="OnHelpClick" Tag="phps" />
                </StackPanel>
                <TextBlock Text="{Binding CustodyDebtSummary}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="Atualizar" Command="{Binding RefreshPhpsMarketCommand}" />
                  <Button Content="Aportar na dívida selecionada" Command="{Binding FundSelectedPhpsDebtCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding PhpsMarketStatus}" Foreground="#F0B37E" TextWrapping="Wrap" />
                <TextBlock Text="Contratos abertos da custódia" FontWeight="Bold" />
                <DataGrid Height="180"
                          ItemsSource="{Binding PhpsMarketItems}"
                          SelectedItem="{Binding SelectedPhpsDebt}"
                          Background="#1A1A1A"
                          Foreground="#EAEAEA"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AutoGenerateColumns="False">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding DebtId}" Width="160" />
                    <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="150" />
                    <DataGridTextColumn Header="Principal" Binding="{Binding Principal}" Width="90" />
                    <DataGridTextColumn Header="Reservado" Binding="{Binding ReservedAmount}" Width="90" />
                    <DataGridTextColumn Header="Retorno" Binding="{Binding PayoutTotal}" Width="90" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                  </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="Minhas posições pHPS" FontWeight="Bold" />
                <DataGrid Height="160"
                          ItemsSource="{Binding MyPhpsDebts}"
                          Background="#1A1A1A"
                          Foreground="#EAEAEA"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          AutoGenerateColumns="False">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding DebtId}" Width="160" />
                    <DataGridTextColumn Header="Principal" Binding="{Binding Principal}" Width="90" />
                    <DataGridTextColumn Header="Reservado" Binding="{Binding ReservedAmount}" Width="90" />
                    <DataGridTextColumn Header="Retorno" Binding="{Binding PayoutTotal}" Width="90" />
                    <DataGridTextColumn Header="Ganho" Binding="{Binding ExpectedGain}" Width="90" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                  </DataGrid.Columns>
                </DataGrid>
              </StackPanel>
            </TabItem>
          </TabControl>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Config">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Configurações" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="config" />
          </StackPanel>
          <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
            <StackPanel Spacing="6">
              <TextBlock Text="Mineração PoW" FontWeight="Bold" Foreground="#EAEAEA" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Threads:" VerticalAlignment="Center" Foreground="#EAEAEA" />
                <NumericUpDown Width="140" Minimum="1" Maximum="{Binding MaxPowThreads}" Value="{Binding PowThreads}" ToolTip.Tip="Quantidade de threads para resolver PoW." />
                <TextBlock Text="{Binding MaxPowThreads, StringFormat=Máx: {0}}" VerticalAlignment="Center" Foreground="#EAEAEA" />
                <Button Content="Salvar" Command="{Binding SavePowSettingsCommand}" ToolTip.Tip="Salva as configurações de PoW." />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
            <StackPanel Spacing="6">
              <TextBlock Text="Automação" FontWeight="Bold" Foreground="#EAEAEA" />
              <CheckBox Content="Assinar pendências automaticamente" IsChecked="{Binding AutoSignTransfers}" Foreground="#EAEAEA" ToolTip.Tip="Assina pendências de transferência automaticamente." />
              <CheckBox Content="Aceitar seleção randômica de minerador automaticamente" IsChecked="{Binding AutoAcceptMinerSelection}" Foreground="#EAEAEA" ToolTip.Tip="Aceita automaticamente a seleção randômica de minerador." />
            </StackPanel>
          </Border>

          <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
            <StackPanel Spacing="6">
              <TextBlock Text="Ajuda" FontWeight="Bold" Foreground="#EAEAEA" />
              <CheckBox Content="Mostrar tour ao abrir" IsChecked="{Binding ShowTourOnStartup}" Foreground="#EAEAEA" ToolTip.Tip="Exibe o tour inicial quando o aplicativo abre." />
              <Button Content="Ver tour agora" Command="{Binding StartTourCommand}" ToolTip.Tip="Abre o tour de primeiros passos." />
            </StackPanel>
          </Border>

          <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
            <StackPanel Spacing="8">
              <TextBlock Text="Preços do Servidor" FontWeight="Bold" Foreground="#EAEAEA" />
              <TextBlock Text="Todos os custos monetários do servidor podem ser ajustados aqui no formato action=valor." TextWrapping="Wrap" Foreground="#CFCFCF" />
              <TextBlock Text="{Binding ServerPriceOwnerLabel}" TextWrapping="Wrap" Foreground="#F0B37E" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Carregar preços" Command="{Binding RefreshServerPriceSettingsCommand}" />
                <Button Content="Salvar preços" Command="{Binding SaveServerPriceSettingsCommand}" />
              </StackPanel>
              <TextBox AcceptsReturn="True"
                       Height="180"
                       Text="{Binding ServerPriceSettingsText}"
                       Watermark="upload=4&#x0a;dns=4"
                       FontFamily="Consolas" />
              <TextBlock Text="{Binding ServerPriceSettingsStatus}" TextWrapping="Wrap" Foreground="#9CD67A" />
            </StackPanel>
          </Border>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Servidores">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Servidores Conhecidos" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="servers" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Novo Servidor:" VerticalAlignment="Center" />
            <TextBox Width="240" Text="{Binding NewServerAddress}" ToolTip.Tip="Digite o endereço do servidor (host:porta)." />
            <Button Content="Adicionar" Command="{Binding AddServerCommand}" ToolTip.Tip="Adiciona o servidor à lista." />
          </StackPanel>
          <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
              <Grid Background="#222222" ColumnDefinitions="*,Auto,Auto" Height="32">
                <TextBlock Text="Endereço" VerticalAlignment="Center" Margin="8,0" Foreground="#EAEAEA" />
                <TextBlock Grid.Column="1" Text="Status" Width="120" VerticalAlignment="Center" Margin="8,0" Foreground="#EAEAEA" />
                <TextBlock Grid.Column="2" Text="Reputação" Width="120" VerticalAlignment="Center" Margin="8,0" Foreground="#EAEAEA" />
              </Grid>
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding KnownServers}"
                       SelectedItem="{Binding SelectedServer}"
                       Background="#1A1A1A"
                       Foreground="#EAEAEA"
                       Height="248"
                       ToolTip.Tip="Selecione um servidor para conectar." >
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:ServerInfo">
                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="8,4">
                      <TextBlock Text="{Binding Address}" Foreground="#EAEAEA" />
                      <TextBlock Grid.Column="1" Text="{Binding Status}" Width="120" Foreground="#EAEAEA" />
                      <TextBlock Grid.Column="2" Text="{Binding Reputation}" Width="120" Foreground="#EAEAEA" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Remover" Command="{Binding RemoveServerCommand}" />
            <Button Content="Conectar" Command="{Binding ConnectServerCommand}" />
            <Button Content="Atualizar" Command="{Binding RefreshServersCommand}" />
          </StackPanel>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Stats">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Estatísticas" FontSize="16" FontWeight="Bold" />
            <Button Content="Ajuda" Click="OnHelpClick" Tag="stats" />
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
          <TextBlock Text="Tempo de Sessão:" Grid.Row="0" />
          <TextBlock Text="{Binding SessionElapsed}" Grid.Row="0" Grid.Column="1" />
          <TextBlock Text="Dados Enviados:" Grid.Row="1" />
          <TextBlock Text="{Binding DataSent}" Grid.Row="1" Grid.Column="1" />
          <TextBlock Text="Dados Recebidos:" Grid.Row="2" />
          <TextBlock Text="{Binding DataReceived}" Grid.Row="2" Grid.Column="1" />
          <TextBlock Text="Conteúdo Baixado:" Grid.Row="3" />
          <TextBlock Text="{Binding ContentDownloadedCount}" Grid.Row="3" Grid.Column="1" />
          <TextBlock Text="Conteúdo Publicado:" Grid.Row="4" />
          <TextBlock Text="{Binding ContentPublishedCount}" Grid.Row="4" Grid.Column="1" />
          <TextBlock Text="DNS Registrados:" Grid.Row="5" />
          <TextBlock Text="{Binding DnsRegisteredCount}" Grid.Row="5" Grid.Column="1" />
            <TextBlock Text="PoW Resolvidos:" Grid.Row="6" />
            <TextBlock Text="{Binding PowSolvedCount}" Grid.Row="6" Grid.Column="1" />
            <TextBlock Text="Tempo Total PoW:" Grid.Row="7" />
            <TextBlock Text="{Binding PowTotalTime}" Grid.Row="7" Grid.Column="1" />
            <TextBlock Text="Conteúdos Reportados:" Grid.Row="8" />
            <TextBlock Text="0" Grid.Row="8" Grid.Column="1" />
          </Grid>
          <Button Content="Atualizar" HorizontalAlignment="Left" />
        </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#1E1E1E" Padding="8" CornerRadius="6">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12">
        <TextBlock Text="{Binding Status}" Foreground="#EAEAEA" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding ContractAlertText}" IsVisible="{Binding ContractAlertVisible}" Foreground="Red" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{Binding BanStatus}" Foreground="Red" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="{Binding Reputation, StringFormat=Reputação: {0}}" Foreground="#EAEAEA" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding DiskUsage, StringFormat=Disco: {0}}" Foreground="#EAEAEA" VerticalAlignment="Center" />
        <TextBlock Grid.Column="5" Text="{Binding User, StringFormat=Usuário: {0}}" Foreground="#EAEAEA" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>

