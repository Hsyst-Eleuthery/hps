<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels"
        x:Class="HpsBrowser.Views.TourWindow"
        x:DataType="vm:MainViewModel"
        Width="520" Height="320"
        WindowStartupLocation="CenterOwner"
        Title="Tour Inicial">
  <StackPanel Spacing="10" Margin="12">
    <TextBlock Text="{Binding TourTitle}" FontSize="16" FontWeight="Bold" />
    <TextBlock Text="{Binding TourBody}" TextWrapping="Wrap" />
    <TextBlock Text="{Binding TourStepLabel}" Foreground="#9A9A9A" />
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="Anterior" Command="{Binding PrevTourCommand}" />
      <Button Content="Próximo" Command="{Binding NextTourCommand}" />
      <Button Content="Fechar" Command="{Binding CloseTourCommand}" />
    </StackPanel>
  </StackPanel>
</Window>
