<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HpsBrowser.Views.ContractReviewWindow"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        Title="Contrato">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="10">
      <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" />
      <TextBlock x:Name="StatusText" Foreground="Red" />

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Hash do contrato:" FontWeight="Bold" />
          <TextBlock x:Name="HashText" />
        </StackPanel>
      </Border>

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Resumo" FontWeight="Bold" />
          <TextBox x:Name="SummaryText" AcceptsReturn="True" Height="120" IsReadOnly="True" />
        </StackPanel>
      </Border>

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Contrato (editável)" FontWeight="Bold" />
          <TextBox x:Name="ContractText" AcceptsReturn="True" Height="180" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Background="#1E1E1E" Padding="8" CornerRadius="6">
        <StackPanel Spacing="6">
          <TextBlock Text="Diff (template vs. atual)" FontWeight="Bold" />
          <TextBox x:Name="DiffText" AcceptsReturn="True" Height="160" IsReadOnly="True" />
        </StackPanel>
      </Border>

      <CheckBox x:Name="AcceptCheck" Content="Li e concordo com os termos deste contrato" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button x:Name="CancelButton" Content="Cancelar" Width="120" />
        <Button x:Name="ConfirmButton" Content="Confirmar" Width="120" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
