<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels"
        x:Class="HpsBrowser.Views.ImportantFlowWindow"
        x:DataType="vm:MainViewModel"
        Width="520" Height="360"
        Title="{Binding ImportantFlowTitle}">
  <Grid>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="10" Margin="12">
        <TextBlock Text="{Binding ImportantFlowTitle}" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="{Binding ImportantFlowStatus}" TextWrapping="Wrap" />
        <TextBlock Text="{Binding ImportantFlowDetails}" TextWrapping="Wrap" />
        <ProgressBar IsIndeterminate="True" Height="6" IsVisible="{Binding IsImportantFlowBusy}" />
        <Border Background="#141414"
                BorderBrush="#2C2C2C"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10">
          <ItemsControl ItemsSource="{Binding ImportantFlowStages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,6"
                        Padding="10"
                        CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="#2C2C2C"
                        Background="#101010"
                        Opacity="{Binding Opacity}">
                  <StackPanel Spacing="4">
                    <Button HorizontalAlignment="Left"
                            Padding="10,6"
                            IsEnabled="{Binding IsActive}"
                            Command="{Binding ActionCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Marker}" Foreground="#EAEAEA" />
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#EAEAEA" />
                      </StackPanel>
                    </Button>
                    <TextBlock Margin="8,0,0,0"
                               Text="{Binding PendingLabel}"
                               Foreground="Red"
                               IsVisible="{Binding BlinkVisible}" />
                    <TextBlock Margin="8,0,0,0"
                               Text="{Binding Detail}"
                               Foreground="#B8B8B8"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
        <TextBox AcceptsReturn="True"
                 MinHeight="160"
                 Text="{Binding ImportantFlowLog}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="Fechar" Command="{Binding CloseImportantFlowCommand}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
    <Border IsVisible="{Binding ImportantFlowCompletedVisible}"
            Background="#66000000"
            IsHitTestVisible="False">
      <TextBlock Text="{Binding ImportantFlowCompletedText}"
                 FontSize="42"
                 FontWeight="Bold"
                 Foreground="#7CFF4D"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
    </Border>
  </Grid>
</Window>
