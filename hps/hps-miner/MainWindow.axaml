<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HpsBrowser.ViewModels;assembly=HpsBrowser.Core"
        xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
        x:Class="HpsMiner.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="920" Height="700"
        MinWidth="860" MinHeight="620"
        Title="HPS Miner">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="12">
    <TextBlock Text="HPS Miner" FontSize="20" FontWeight="Bold" />

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="12">
        <Border Background="#1A1A1A" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Conexao" FontWeight="Bold" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <TextBlock Text="Servidor:" Grid.Row="0" />
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ServerAddress}" Watermark="host:porta" />

              <TextBlock Text="Usuario:" Grid.Row="1" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Username}" />

              <TextBlock Text="Senha:" Grid.Row="2" />
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding KeyPassphrase}" PasswordChar="*" />

              <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
                <CheckBox Content="Usar SSL/TLS" IsChecked="{Binding UseSsl}" />
                <CheckBox Content="Reconexao automatica" IsChecked="{Binding AutoReconnect}" />
              </StackPanel>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Conectar" Command="{Binding EnterNetworkCommand}" />
              <Button Content="Desconectar" Command="{Binding ExitNetworkCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding Status}" />
            <TextBlock Text="{Binding LoginStatus}" Foreground="#F0B37E" />
          </StackPanel>
        </Border>

        <Border Background="#1A1A1A" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Mineracao" FontWeight="Bold" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
              <TextBlock Text="Status:" Grid.Row="0" />
              <TextBlock Text="{Binding HpsMiningStatus}" Grid.Row="0" Grid.Column="1" />
              <TextBlock Text="Bits alvo:" Grid.Row="1" />
              <TextBlock Text="{Binding HpsMiningBits}" Grid.Row="1" Grid.Column="1" />
              <TextBlock Text="Hashrate:" Grid.Row="2" />
              <TextBlock Text="{Binding HpsMiningHashrate}" Grid.Row="2" Grid.Column="1" />
              <TextBlock Text="Tentativas:" Grid.Row="3" />
              <TextBlock Text="{Binding HpsMiningAttempts}" Grid.Row="3" Grid.Column="1" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Minerar HPS" Command="{Binding StartHpsMintCommand}" />
              <Button Content="Assinar proxima pendencia" Command="{Binding SignNextPendingTransferCommand}" />
              <Button Content="Pagar multa" Command="{Binding RequestMinerFineCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
              <CheckBox Content="Mineracao continua" IsChecked="{Binding IsContinuousMiningEnabled}" />
              <CheckBox Content="Auto-assinar pendencias" IsChecked="{Binding AutoSignTransfers}" />
              <CheckBox Content="Auto-aceitar selecao" IsChecked="{Binding AutoAcceptMinerSelection}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
              <CheckBox Content="Pagar multa automaticamente" IsChecked="{Binding MinerAutoPayFine}" />
              <CheckBox Content="Promessa automatica" IsChecked="{Binding MinerFinePromise}" />
            </StackPanel>

            <TextBlock Text="{Binding MinerPendingSignatures, StringFormat=Pendencias de assinatura: {0}}" />
            <TextBlock Text="{Binding MinerPendingFines, StringFormat=Multas pendentes: {0}}" />
            <TextBlock Text="{Binding MinerFinePerPending, StringFormat=Multa por pendencia: {0}}" />
            <TextBlock Text="{Binding MinerFineStatus}" Foreground="#F0B37E" />
          </StackPanel>
        </Border>

        <Border Background="#1A1A1A" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Fluxo Operacional" FontWeight="Bold" />
            <TextBlock Text="{Binding ImportantFlowStatus}" TextWrapping="Wrap" Foreground="#EAEAEA" />
            <TextBlock Text="{Binding PendingTransferStatus}" TextWrapping="Wrap" Foreground="#F0B37E" />
            <TextBlock Text="{Binding HpsWalletAlert}" TextWrapping="Wrap" Foreground="#9CD67A" />
            <TextBlock Text="{Binding PendingTransfersCount, StringFormat=Transferencias pendentes: {0}}" />
          </StackPanel>
        </Border>

        <Border Background="#1A1A1A" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
          <StackPanel Spacing="8">
            <TextBlock Text="Configuracao" FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Threads PoW:" VerticalAlignment="Center" />
              <controls:NumericUpDown Width="140" Minimum="1" Maximum="{Binding MaxPowThreads}" Value="{Binding PowThreads}" />
              <TextBlock Text="{Binding MaxPowThreads, StringFormat=Max: {0}}" VerticalAlignment="Center" />
              <Button Content="Salvar Threads" Command="{Binding SavePowSettingsCommand}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Gerar Chaves" Command="{Binding GenerateKeysCommand}" />
              <Button Content="Exportar Chaves" Command="{Binding ExportKeysCommand}" />
              <Button Content="Importar Chaves" Command="{Binding ImportKeysCommand}" />
            </StackPanel>

            <TextBlock Text="Chave publica:" />
            <TextBox AcceptsReturn="True" Height="100" Text="{Binding PublicKeyPem}" IsReadOnly="True" />
          </StackPanel>
        </Border>

        <Border Background="#1A1A1A" BorderBrush="#2C2C2C" BorderThickness="1" CornerRadius="6" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock Text="Log" FontWeight="Bold" />
            <TextBox AcceptsReturn="True" Height="180" Text="{Binding PowLogText}" IsReadOnly="True" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#1E1E1E" Padding="8" CornerRadius="6">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding User, StringFormat=Usuario: {0}}" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
